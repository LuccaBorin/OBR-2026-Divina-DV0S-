// ======================================================
// BIBLIOTECAS
// ======================================================
#include <RoboCore_Vespa.h>
// ======================================================
// OBJETOS
// ======================================================
VespaMotors motors;
// ======================================================
// DEFINES
// ======================================================

#define LpE 17  //Linha ponta esquerda L2
#define LcE 16  //Linha centro esquerda L1
#define Lm 18   //Linha centro M
#define LcD 5   //Linha centro direita R1
#define LpD 23  //Linha ponta direita R2

// ======================================================
// VARIAVEIS
// ======================================================
int spd = 50;  //vai de 0 a 100
bool valLpE, valLcE, valLm, valLcD, valLpD;
// ======================================================
// FUNÇÕES
// ======================================================
void Leituras();
void SegueLinha();
void Mover(char dir, int spd, int time);
// ======================================================
// SETUP
// ======================================================
void setup() {
  Serial.begin(115200);
}
// ======================================================
// LOOP
// ======================================================
void loop() {
  Leituras();
  SegueLinha();
  Leituras();
}

// ======================================================
// FUNÇÕES
// ======================================================
// ======== MOVER ========
void Mover(char dir, int spd, int time) {
  if (spd < 0) spd = 0;
  if (spd > 100) spd = 100;

  switch (dir) {
    case 'f':
      motors.forward(spd);
      break;
    case 't':
      motors.backward(spd);
      break;
    case 'd':
      motors.setSpeedLeft(spd);
      motors.setSpeedRight(-spd);
      break;
    case 'e':
      motors.setSpeedLeft(-spd);
      motors.setSpeedRight(spd);
      break;
    case 'p':
    default:
      motors.stop();
      break;
  }
  delay(time);
  motors.stop();
  Leituras();
}
// ======== LEITURAS ========
void Leituras() {
  // ======== LINHA ========
  valLpE = digitalRead(LpE);
  valLcE = digitalRead(LcE);
  valLm = digitalRead(Lm);
  valLcD = digitalRead(LcD);
  valLpD = digitalRead(LpD);
 // ======== MONITOR SERIAL ========
  Serial.print("LpE: ");
  Serial.print(valLpE);
  Serial.print(" | LcE: ");
  Serial.print(valLcE);
  Serial.print(" | Lm: ");
  Serial.print(valLm);
  Serial.print(" | LcD: ");
  Serial.print(valLcD);
  Serial.print(" | LpD: ");
  Serial.println(valLpD);
}
// ======== SEGUE LINHA ========
void SegueLinha() {
  if (valLpE) {//-------- CURVA DE 90 GRAUS DA ESQUERDA --------
    Mover('p', spd, 1000);
    Mover('f', spd, 700);
    Mover('p', spd, 1000);
    while (!valLm) {
      Mover('e', spd, 5);
    }
    Mover('e', spd, 100);
  } else if (valLpD) {//-------- CURVA DE 90 GRAUS DA DIREITA --------
    Mover('p', spd, 1000);
    Mover('f', spd, 700);
    Mover('p', spd, 1000);
    while (!valLm) {
      Mover('d', spd, 5);
    }
    Mover('d', spd, 100);
  } else if (valLcE) {//-------- CURVA LEVE DA ESQUERDA --------
    Mover('e', spd, 100);
    Mover('f', spd, 50);
  } else if (valLcD) {//-------- CURVA LEVE DA DIREITA --------
    Mover('d', spd, 100);
    Mover('f', spd, 50);
  } else {//-------- DEFAULT --------
    Mover('f', spd, 10);
  }
}
