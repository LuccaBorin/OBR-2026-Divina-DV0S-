//DEFINES--
#define LpE 
#define LcE 
#define Lm 
#define LcD 
#define LpD 

//VARIAVEIS--
int valLpE,valLcE,valLm,valLcD,valLpD;
int med1,med2,med3;


//FUNÇÕES--
void Leituras();
void SegueLinha();
void Calibragem();

void setup() {
Serial.begin(115200);
pinMode(LpE,INPUT);
pinMode(LcE,INPUT);
pinMode(Lm,INPUT);
pinMode(LcD,INPUT);
pinMode(LpD,INPUT);
}

void loop() {
Leituras();
SegueLinha();
Leituras();
}

//FUNÇÕES--
void Leituras(){
  Serial.Println(analogRead(LpE));
}
